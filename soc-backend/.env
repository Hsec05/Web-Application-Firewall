# ─── PostgreSQL Connection ─────────────────────────────────────────────────────
# Fill in YOUR pgAdmin credentials below.
# Either use DATABASE_URL (one line) OR the individual fields below.

# Option A — Single connection string (recommended):
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/waf_dashboard

# Option B — Individual fields (if you prefer):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=waf_dashboard
DB_USER=postgres
DB_PASSWORD= Add your password here

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:8080

#Target site
TARGET_SITE=http://localhost:3000

# ─── Optional: AbuseIPDB for IP Intelligence ──────────────────────────────────
# Get a free key at https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY= add your Abuse IP DB api key here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER= add your mail here
SMTP_PASS= add your app pass code here
